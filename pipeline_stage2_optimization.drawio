        <mxCell id="p2_bend_header" value="PHƯƠNG ÁN 2: BENDERS DECOMPOSITION" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;strokeWidth=1.5;fontSize=11;align=center;fontColor=#1b5e20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="220" width="340" height="45" as="geometry" />
        </mxCell>
        <mxCell id="p2_bend1" value="&lt;table border=&quot;0&quot; style=&quot;width:100%; border-collapse:collapse;&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot; valign=&quot;middle&quot; style=&quot;width:45px; font-size:24px; color:#1b5e20;&quot;&gt;🗄️&lt;/td&gt;&lt;td align=&quot;left&quot; valign=&quot;middle&quot; style=&quot;font-size:10px; font-family:Arial, sans-serif; color:#1b5e20; line-height:1.2;&quot;&gt;&lt;b&gt;1. Khởi tạo&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color:#555555;&quot;&gt;• Tạo Master Problem&lt;br/&gt;• LB = -∞, UB = +∞, ε &amp;gt; 0&lt;br/&gt;• Thêm Benders cut ban đầu (nếu có)&lt;/span&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;html=1;fillColor=#ffffff;strokeColor=#2e7d32;strokeWidth=1.5;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="580" y="285" width="340" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p2_bend_loop_container" value="VÒNG LẶP BENDERS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#2e7d32;strokeWidth=1.5;dashed=1;fontSize=11;fontStyle=1;verticalAlign=top;align=center;spacingTop=6;fontColor=#2e7d32;" vertex="1" parent="1">
          <mxGeometry x="560" y="375" width="380" height="360" as="geometry" />
        </mxCell>
        <mxCell id="p2_bend2" value="&lt;table border=&quot;0&quot; style=&quot;width:100%; border-collapse:collapse;&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot; valign=&quot;middle&quot; style=&quot;width:45px; font-size:24px; color:#1b5e20;&quot;&gt;📦&lt;/td&gt;&lt;td align=&quot;left&quot; valign=&quot;middle&quot; style=&quot;font-size:10px; font-family:Arial, sans-serif; color:#1b5e20; line-height:1.2;&quot;&gt;&lt;b&gt;2. Giải Master Problem (MILP)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color:#555555;&quot;&gt;Quyết định mở kho y^t | Thu cận dưới LB^t&lt;/span&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;html=1;fillColor=#ffffff;strokeColor=#2e7d32;strokeWidth=1.5;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="580" y="405" width="340" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p2_bend3" value="&lt;table border=&quot;0&quot; style=&quot;width:100%; border-collapse:collapse;&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot; valign=&quot;middle&quot; style=&quot;width:45px; font-size:24px; color:#1b5e20;&quot;&gt;🗄️&lt;/td&gt;&lt;td align=&quot;left&quot; valign=&quot;middle&quot; style=&quot;font-size:10px; font-family:Arial, sans-serif; color:#1b5e20; line-height:1.2;&quot;&gt;&lt;b&gt;3. Giải Subproblem (LP)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color:#555555;&quot;&gt;Cố định y^t và giải LP phân bổ nhu cầu&lt;br/&gt;Thu nghiệm đối ngẫu (u^t, v^t, w^t)&lt;/span&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;html=1;fillColor=#ffffff;strokeColor=#2e7d32;strokeWidth=1.5;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="580" y="475" width="340" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p2_bend4" value="&lt;table border=&quot;0&quot; style=&quot;width:100%; border-collapse:collapse;&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot; valign=&quot;middle&quot; style=&quot;width:45px; font-size:24px; color:#1b5e20;&quot;&gt;📄&lt;/td&gt;&lt;td align=&quot;left&quot; valign=&quot;middle&quot; style=&quot;font-size:10px; font-family:Arial, sans-serif; color:#1b5e20; line-height:1.2;&quot;&gt;&lt;b&gt;4. Sinh Benders Cut&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color:#555555;&quot;&gt;• Optimality cut (nếu khả thi)&lt;br/&gt;• Feasibility cut (nếu vô hạn)&lt;/span&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;html=1;fillColor=#ffffff;strokeColor=#2e7d32;strokeWidth=1.5;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="580" y="545" width="340" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p2_bend5" value="&lt;table border=&quot;0&quot; style=&quot;width:100%; border-collapse:collapse;&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot; valign=&quot;middle&quot; style=&quot;width:45px; font-size:24px; color:#1b5e20;&quot;&gt;✂️&lt;/td&gt;&lt;td align=&quot;left&quot; valign=&quot;middle&quot; style=&quot;font-size:10px; font-family:Arial, sans-serif; color:#1b5e20; line-height:1.2;&quot;&gt;&lt;b&gt;5. Thêm Benders Cut vào Master&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color:#555555;&quot;&gt;Bổ sung ràng buộc cắt vào Master&lt;/span&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;html=1;fillColor=#ffffff;strokeColor=#2e7d32;strokeWidth=1.5;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="580" y="615" width="340" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2_bend6" value="&lt;table border=&quot;0&quot; style=&quot;width:100%; border-collapse:collapse;&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot; valign=&quot;middle&quot; style=&quot;width:45px; font-size:24px; color:#1b5e20;&quot;&gt;✅&lt;/td&gt;&lt;td align=&quot;left&quot; valign=&quot;middle&quot; style=&quot;font-size:10px; font-family:Arial, sans-serif; color:#1b5e20; line-height:1.2;&quot;&gt;&lt;b&gt;6. Cập nhật cận&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color:#555555;&quot;&gt;• Cập nhật UB từ nghiệm khả thi&lt;br/&gt;• Kiểm tra điều kiện hội tụ: UB - LB ≤ ε&lt;/span&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;html=1;fillColor=#ffffff;strokeColor=#2e7d32;strokeWidth=1.5;align=left;spacingLeft=5;" vertex="1" parent="1">
