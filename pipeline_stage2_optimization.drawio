        <mxCell id="p2_milp_header" value="PHƯƠNG ÁN 1: MILP NGUYÊN KHỐI&#10;(Thuật toán Nhánh và Cắt)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;strokeWidth=1.5;fontSize=11;align=center;fontColor=#0d47a1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="220" width="340" height="45" as="geometry" />
        </mxCell>
        <mxCell id="p2_milp1" value="&lt;table border=&quot;0&quot; style=&quot;width:100%; border-collapse:collapse;&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot; valign=&quot;middle&quot; style=&quot;width:45px; font-size:24px; color:#0d47a1;&quot;&gt;📦&lt;/td&gt;&lt;td align=&quot;left&quot; valign=&quot;middle&quot; style=&quot;font-size:10px; font-family:Arial, sans-serif; color:#0d47a1; line-height:1.2;&quot;&gt;&lt;b&gt;1. Xây dựng mô hình MILP nguyên khối&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color:#555555;&quot;&gt;• Biến quyết định: X_ij, y_j&lt;br/&gt;• Hàm mục tiêu: Min Z = ∑_i ∑_j C_ij X_ij + ∑_j f_j y_j&lt;br/&gt;• Các ràng buộc CFLP&lt;/span&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;html=1;fillColor=#ffffff;strokeColor=#1976d2;strokeWidth=1.5;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="100" y="285" width="340" height="95" as="geometry" />
        </mxCell>
        <mxCell id="p2_milp2" value="&lt;table border=&quot;0&quot; style=&quot;width:100%; border-collapse:collapse;&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot; valign=&quot;middle&quot; style=&quot;width:45px; font-size:24px; color:#0d47a1;&quot;&gt;🌳&lt;/td&gt;&lt;td align=&quot;left&quot; valign=&quot;middle&quot; style=&quot;font-size:10px; font-family:Arial, sans-serif; color:#0d47a1; line-height:1.2;&quot;&gt;&lt;b&gt;2. Giải bài toán MILP&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color:#555555;&quot;&gt;Sử dụng thuật toán nhánh và cắt (Branch-and-Cut)&lt;/span&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;html=1;fillColor=#ffffff;strokeColor=#1976d2;strokeWidth=1.5;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="100" y="405" width="340" height="65" as="geometry" />
        </mxCell>
        <mxCell id="p2_milp3" value="&lt;table border=&quot;0&quot; style=&quot;width:100%; border-collapse:collapse;&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot; valign=&quot;middle&quot; style=&quot;width:45px; font-size:24px; color:#0d47a1;&quot;&gt;📈&lt;/td&gt;&lt;td align=&quot;left&quot; valign=&quot;middle&quot; style=&quot;font-size:10px; font-family:Arial, sans-serif; color:#0d47a1; line-height:1.2;&quot;&gt;&lt;b&gt;3. Thu nghiệm tối ưu&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color:#555555;&quot;&gt;• Chi phí tối ưu (Z*)&lt;br/&gt;• Vị trí kho (y_j*)&lt;br/&gt;• Phân bổ nhu cầu (X_ij*)&lt;/span&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;html=1;fillColor=#ffffff;strokeColor=#1976d2;strokeWidth=1.5;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="100" y="495" width="340" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p2_milp4" value="&lt;table border=&quot;0&quot; style=&quot;width:100%; border-collapse:collapse;&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot; valign=&quot;middle&quot; style=&quot;width:45px; font-size:24px; color:#0d47a1;&quot;&gt;⏱️&lt;/td&gt;&lt;td align=&quot;left&quot; valign=&quot;middle&quot; style=&quot;font-size:10px; font-family:Arial, sans-serif; color:#0d47a1; line-height:1.2;&quot;&gt;&lt;b&gt;4. Ghi nhận kết quả&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color:#555555;&quot;&gt;Lưu kết quả tháng hiện tại&lt;/span&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;html=1;fillColor=#ffffff;strokeColor=#1976d2;strokeWidth=1.5;align=left;spacingLeft=5;" vertex="1" parent="1">
